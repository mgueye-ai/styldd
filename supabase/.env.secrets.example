# Copy to supabase/.env.secrets (gitignored) then: npx supabase login && npm run secrets:set
#
# Dashboard: https://supabase.com/dashboard/project/gogpjxxsrcjpbugocvnd/settings/functions
# Use "Edge Functions" → "Secrets" on project gogpjxxsrcjpbugocvnd (NOT the site-data project).
#
# Rules:
# - Names must match exactly (case-sensitive): UNIT_API_TOKEN, UNIT_API_URL, PLAID_CLIENT_ID, PLAID_SECRET, PLAID_ENV
# - Paste values with NO quotes and NO line breaks (full Unit token is ~2000+ characters on one line)
# - Sandbox Unit tokens use https://api.s.unit.sh — NOT https://api.unit.co

UNIT_API_TOKEN=your-unit-bearer-token-starts-with-v2.public
UNIT_API_URL=https://api.s.unit.sh
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-sandbox-or-production-secret
PLAID_ENV=sandbox
