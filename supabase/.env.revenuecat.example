# Copy to supabase/.env.revenuecat (gitignored) then: npm run secrets:set:revenuecat
#
# GET /v1/subscribers requires PUBLIC SDK keys (appl_/goog_/test_), NOT sk_ secret keys.
# Find these in RevenueCat Dashboard → your app → API keys (same keys used in the mobile SDK).
#
# sk_ secret keys are only for grant/revoke/delete — do not use them for subscriber lookups.

REVENUECAT_IOS_PUBLIC_KEY=appl_your_ios_public_key
REVENUECAT_ANDROID_PUBLIC_KEY=goog_or_test_your_android_public_key

# RevenueCat Dashboard → Integrations → Webhooks → Authorization header (same value).
# Webhook URL: https://gogpjxxsrcjpbugocvnd.supabase.co/functions/v1/revenuecat-webhook
# Subscribe at minimum to: EXPIRATION
REVENUECAT_WEBHOOK_SECRET=your_random_webhook_secret
