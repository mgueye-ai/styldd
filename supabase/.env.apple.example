# Apple Sign In — used by: npm run gen:apple-secret
# Copy to supabase/.env.apple (do NOT commit the real file or .p8 key)

APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_CLIENT_ID=com.crmstyld.app
APPLE_PRIVATE_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# Supabase Dashboard → Authentication → Providers → Apple → Client IDs (comma-separated):
#   com.crmstyld.app
# Optional if testing in Expo Go:
#   host.exp.Exponent
# Native sign-in sends an id_token whose audience is the bundle ID — NOT the Services ID.
# Secret Key is only required for web OAuth; native signInWithIdToken does not need it.
