{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/tenant", "destination": "/tenant/index.html" },
    { "source": "/marketing", "destination": "/marketing/index.html" },
    { "source": "/connect/return", "destination": "/connect/return.html" },
    { "source": "/connect/refresh", "destination": "/connect/refresh.html" }
  ]
}
