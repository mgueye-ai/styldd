EXPO_PUBLIC_LOGOKIT_TOKEN=        # LogoKit publishable key (pk_...) — bank logo display
EXPO_PUBLIC_SUPABASE_URL=https://your-styld-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-styld-publishable-or-anon-key

# External salon site data project (where linked tables like hairbynadjae_site live)
EXPO_PUBLIC_SITE_DATA_SUPABASE_URL=https://your-site-project-ref.supabase.co
EXPO_PUBLIC_SITE_DATA_SUPABASE_ANON_KEY=your-site-publishable-or-anon-key
EXPO_PUBLIC_LINKED_SITE_WEB_URL=https://www.your-salon-site.com

# Public site domain (used for subdomain preview URLs)
EXPO_PUBLIC_STYLD_ROOT_DOMAIN=styldd.com

# RevenueCat — public SDK keys (safe in the app; set per platform in RevenueCat dashboard)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key
# RevenueCat public keys for server subscriber lookup → supabase/.env.revenuecat → npm run secrets:set:revenuecat

# Stripe publishable key (client-side; optional if only using Connect via edge functions)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# OpenAI — set the same value in Supabase Dashboard → Edge Functions → Secrets
OPENAI_API_KEY=sk-proj-your-openai-key

# Vercel redeploy on publish — set these in Supabase Edge Function secrets (not in the Expo app)
# Team ID is team_VMPq0V7TAeaO8qcXLEwZfAoO (letter O + 8, not "08")
VERCEL_ACCESS_TOKEN=
VERCEL_PROJECT_ID=prj_P0uGjfgjUgZseTbapw72sD2ZhCSs
VERCEL_TEAM_ID=team_VMPq0V7TAeaO8qcXLEwZfAoO
# Optional simpler alternative: Vercel Deploy Hook URL (Settings → Git → Deploy Hooks)
VERCEL_DEPLOY_HOOK_URL=

# Never put secret/service role keys in the app.

# Unit + Plaid (Supabase Edge Function secrets only — never in the Expo app)
# UNIT_API_TOKEN=your-unit-bearer-token
# UNIT_API_URL=https://api.s.unit.sh
# PLAID_CLIENT_ID=your-plaid-client-id
# PLAID_SECRET=your-plaid-sandbox-or-production-secret
# PLAID_ENV=sandbox
